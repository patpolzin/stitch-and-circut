{
  "schema_version": 1,
  "description": "Canonical KnitBit character-builder manifest. Single source of truth for the base rig, every trait's source mesh + fit transform, and the named preset loadouts. Read by tools/knitbit_manifest.py (pure Python), tools/build_character.py (Blender assembler), and tools/fit_traits.py. See docs/KnitBit-Base-Spec.md sections 4-6.",

  "base": {
    "rig": "knitbit_base_rigged.glb",
    "comment": "char_height / half_width come from the base mesh bounds printed by tools/rig_knitbit.py (min=(-0.738,-0.371,-0.957) max=(0.733,0.373,0.954), Blender Z-up). All fit.scale values are fractions of char_height; fit.offset_frac is in socket-local space, also as fractions of char_height.",
    "char_height": 1.911,
    "half_width": 0.735
  },

  "sockets": [
    "socket_head_top_center",
    "socket_head_left_antenna",
    "socket_head_right_antenna",
    "socket_head_left_side",
    "socket_head_right_side",
    "socket_faceplate",
    "socket_chest_center",
    "socket_belt_front",
    "socket_belt_left",
    "socket_belt_right",
    "socket_back_center",
    "socket_left_hand_grip",
    "socket_right_hand_grip",
    "socket_left_boot_front",
    "socket_right_boot_front"
  ],

  "slots": {
    "antenna": {
      "label": "Antenna",
      "comment": "mount:antenna_pair traits fit on socket_head_left_antenna + socket_head_right_antenna (right mirrored on x)."
    },
    "helmet_panel": {
      "label": "Head Top Panel",
      "comment": "Low-profile surface detail on socket_head_top_center only. Never dome/helmet geometry (the head IS the helmet, spec section 1)."
    },
    "chest_icon": { "label": "Chest Icon" },
    "belt_charm": { "label": "Belt Charm" },
    "accessory": {
      "label": "Accessory",
      "comment": "Each accessory carries its own socket (backpack -> back_center, headphones -> head_top_center, watering can -> right_hand_grip)."
    }
  },

  "traits": [
